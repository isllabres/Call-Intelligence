# Required for AI analysis
ANTHROPIC_API_KEY=sk-ant-...

# Required for speaker diarization (optional feature)
# Get your token at https://huggingface.co/settings/tokens
# You must also accept the model conditions at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_...

# Whisper model size: tiny.en, base.en, small.en, medium.en, large-v3
# Larger = more accurate but slower. ".en" variants are better for English-only.
WHISPER_MODEL=base.en

# Your name as it appears in transcripts (for speech analysis)
MY_SPEAKER_NAME=Me

# Google Suite integration is configured via OAuth (run: call-intel auth)
# Place your client_secret.json in .credentials/
# See README for Google Cloud setup instructions
